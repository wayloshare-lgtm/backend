    {
      "name": "2. Authentication",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('sanctum_token', jsonData.token);",
                  "    pm.environment.set('user_id', jsonData.user.id);",
                  "    console.log('✓ Token saved: ' + jsonData.token);",
                  "    console.log('✓ User ID saved: ' + jsonData.user.id);",
                  "} else {",
                  "    console.log('✗ Login failed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/v1/auth/login",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login with Firebase token - returns Sanctum API token. Token is automatically saved to environment."
          },
          "response": []
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sanctum_token}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/api/v1/auth/me",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Get current user profile"
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Rides",
      "item": [
        {
          "name": "POST /rides (Request Ride)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('ride_id', jsonData.ride.id);",
                  "    console.log('✓ Ride ID saved: ' + jsonData.ride.id);",
                  "} else {",
                  "    console.log('✗ Ride creation failed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sanctum_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_location\": \"123 Main St, Downtown\",\n  \"pickup_lat\": 32.7266,\n  \"pickup_lng\": 74.8570,\n  \"dropoff_location\": \"456 Oak Ave, Uptown\",\n  \"dropoff_lat\": 32.7100,\n  \"dropoff_lng\": 74.8500,\n  \"estimated_distance_km\": 12,\n  \"estimated_duration_minutes\": 20\n}"
